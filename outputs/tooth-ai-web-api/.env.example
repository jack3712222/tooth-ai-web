LOCAL_TRUSTED_MODE=0
ADMIN_USERNAME=dentex-admin
ADMIN_PASSWORD=set-a-long-unique-local-password
SESSION_TTL_SECONDS=28800

# The model must be mounted or stored on the deployment host; never commit it.
MODEL_PATH=/opt/tooth-ai/models/current_model.pt
CORS_ORIGINS=https://jack3712222.github.io
MAX_UPLOAD_BYTES=8388608
MAX_IMAGE_PIXELS=30000000
BACKUP_INTERVAL_SECONDS=300
SLICER_URL=http://127.0.0.1:18901
ALLOW_MOCK=0
ENABLE_SLICER_BRIDGE=0
